# ai/image_search 환경 변수 예시
# 이 파일을 복사해 .env 로 만들고 실제 키 값을 채우세요:  cp .env.example .env
# (.env 는 git 에 커밋하지 마세요 — 루트 .gitignore 의 `.env` 규칙으로 무시됩니다)

# Google Places API (장소명 -> 좌표/근처 검색). route_planner 와 같은 키 재사용 가능
GOOGLE_MAPS_API_KEY=

# Google Cloud Vision API (랜드마크 감지, REST). 같은 GCP 프로젝트면 Maps 키 재사용 가능 (Vision API 활성화 필요)
GOOGLE_CLOUD_VISION_API_KEY=

# Google Gemini API (비전 LLM). Google AI Studio 에서 발급
GEMINI_API_KEY=
