# Copy this file to deploy/chiwawa.production.env on the server.
# Keep the copied file out of git; it contains production secrets.

CHIWAWA_BIND_HOST=172.17.0.1
CHIWAWA_HTTP_PORT=8082
CHIWAWA_RUNTIME_UID=1000
CHIWAWA_RUNTIME_GID=1000
API_BASE_URL=https://chiwawa.jmllem.com
USE_API=true
REQUIRE_AUTH=true
PUBLIC_BASE_URL=https://chiwawa.jmllem.com
PHOTO_SEARCH_UPLOAD_DIR=/data/photo_search_uploads

JWT_SECRET=replace-with-a-random-secret-at-least-32-characters

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=
GOOGLE_CLOUD_VISION_API_KEY=
GEMINI_API_KEY=
IMAGE_SEARCH_URL=

# These values are overridden by docker-compose.production.yml, but are listed
# here so the same file is also usable for direct backend diagnostics.
CORS_ALLOW_ORIGINS=https://chiwawa.jmllem.com
GOOGLE_REDIRECT_URI=https://chiwawa.jmllem.com/api/v1/auth/google/callback
GOOGLE_OAUTH_COOKIE_SECURE=true
